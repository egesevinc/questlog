# Normalise line endings: the repo stores LF, checkouts use the platform default.
* text=auto

# Source files always LF in the repo.
*.cs      text eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.json    text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.svg binary
*.ico binary
